---
interface GalleryItem {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  gallery?: GalleryItem[];
}

const { gallery = [] } = Astro.props;
const hasGallery = gallery.length > 0;
const firstItem = gallery[0];
---

{hasGallery && firstItem && (
  <section id="model-gallery" class="model-gallery" aria-label="Model image gallery" data-model-gallery>
    <div class="gallery-stage">
      <img
        class="main-image"
        src={firstItem.src}
        alt={firstItem.alt}
        loading="eager"
        data-main-image
      />
    </div>

    <p class="main-caption" data-main-caption>{firstItem.caption ?? firstItem.alt}</p>

    <div class="thumb-strip" role="list" aria-label="Gallery thumbnails">
      {gallery.map((item, index) => (
        <button
          type="button"
          class:list={["thumb", index === 0 && "is-active"]}
          role="listitem"
          aria-label={`View image ${index + 1}`}
          aria-pressed={index === 0 ? "true" : "false"}
          data-thumb
          data-src={item.src}
          data-alt={item.alt}
          data-caption={item.caption ?? item.alt}
        >
          <img src={item.src} alt={item.alt} loading="lazy" />
        </button>
      ))}
    </div>
  </section>
)}

<script is:inline>
  const galleries = document.querySelectorAll("[data-model-gallery]");

  galleries.forEach((gallery) => {
    const stage = gallery.querySelector(".gallery-stage");
    const mainImage = gallery.querySelector("[data-main-image]");
    const mainCaption = gallery.querySelector("[data-main-caption]");
    const thumbs = gallery.querySelectorAll("[data-thumb]");

    if (!stage || !mainImage || !mainCaption || thumbs.length === 0) return;

    let activeIndex = 0;
    let touchStartX = null;

    const setActive = (index) => {
      const thumb = thumbs[index];
      if (!thumb) return;

      const nextSrc = thumb.getAttribute("data-src");
      const nextAlt = thumb.getAttribute("data-alt");
      const nextCaption = thumb.getAttribute("data-caption");

      if (!nextSrc || !nextAlt) return;

      mainImage.setAttribute("src", nextSrc);
      mainImage.setAttribute("alt", nextAlt);
      mainCaption.textContent = nextCaption || nextAlt;

      thumbs.forEach((button) => {
        button.classList.remove("is-active");
        button.setAttribute("aria-pressed", "false");
      });

      thumb.classList.add("is-active");
      thumb.setAttribute("aria-pressed", "true");
      activeIndex = index;
    };

    const goToNext = () => {
      const nextIndex = (activeIndex + 1) % thumbs.length;
      setActive(nextIndex);
    };

    const goToPrevious = () => {
      const previousIndex = (activeIndex - 1 + thumbs.length) % thumbs.length;
      setActive(previousIndex);
    };

    thumbs.forEach((thumb, index) => {
      thumb.addEventListener("click", () => {
        setActive(index);
      });
    });

    stage.addEventListener(
      "touchstart",
      (event) => {
        touchStartX = event.changedTouches[0]?.clientX ?? null;
      },
      { passive: true },
    );

    stage.addEventListener(
      "touchend",
      (event) => {
        if (touchStartX === null) return;

        const touchEndX = event.changedTouches[0]?.clientX;
        if (typeof touchEndX !== "number") {
          touchStartX = null;
          return;
        }

        const deltaX = touchEndX - touchStartX;
        const swipeThreshold = 35;

        if (Math.abs(deltaX) >= swipeThreshold) {
          if (deltaX < 0) {
            goToNext();
          } else {
            goToPrevious();
          }
        }

        touchStartX = null;
      },
      { passive: true },
    );
  });
</script>

<style>
  .model-gallery {
    margin-bottom: 1.5rem;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--border) 76%);
    border-radius: var(--radius);
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--accent-light) 70%, transparent) 0%, transparent 56%),
      color-mix(in srgb, var(--bg-secondary) 84%, var(--bg) 16%);
  }

  .gallery-stage {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--border) 80%);
    background: color-mix(in srgb, var(--bg) 92%, black 8%);
    touch-action: pan-y;
  }

  .main-image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 0;
  }

  .main-caption {
    margin: 0.6rem 0 0;
    font-size: 0.9rem;
    color: var(--text-muted);
    min-height: 1.2rem;
  }

  .thumb-strip {
    margin-top: 0.85rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(84px, 1fr));
    gap: 0.55rem;
  }

  .thumb {
    appearance: none;
    border: 2px solid transparent;
    border-radius: 10px;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    background: transparent;
    transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .thumb img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  .thumb:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--accent) 55%, var(--border) 45%);
  }

  .thumb.is-active {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 25%, transparent);
  }

  .thumb:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--accent) 55%, transparent);
    outline-offset: 1px;
  }
</style>
