---
interface AdviceSetting {
  label: string;
  value: string;
}

interface PrintAdviceData {
  settings?: AdviceSetting[];
  notes?: string;
}

interface Props {
  printAdvice?: PrintAdviceData;
}

const { printAdvice } = Astro.props;
const settings = printAdvice?.settings ?? [];
const hasNotes = Boolean(printAdvice?.notes);
const hasContent = settings.length > 0 || hasNotes;
---

{hasContent && (
  <section id="print-advice" class="print-advice" aria-label="Print advice">
    <div class="advice-header">
      <p class="eyebrow">Print Advice</p>
      <h2>Dial-In Guide</h2>
      <p class="subtitle">Suggested settings for a reliable print result.</p>
    </div>

    {settings.length > 0 && (
      <dl class="advice-table" role="presentation">
        {settings.map((item) => (
          <div class="advice-row">
            <dt class="advice-key">{item.label}</dt>
            <dd class="advice-value">{item.value}</dd>
          </div>
        ))}
      </dl>
    )}

    {printAdvice?.notes && <p class="advice-notes">{printAdvice.notes}</p>}
  </section>
)}

<style>
  .print-advice {
    margin: 2rem 0;
    padding: 1.1rem;
    border: 1px solid color-mix(in srgb, var(--accent) 40%, var(--border) 60%);
    border-radius: var(--radius);
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--accent-light) 80%, transparent) 0%, transparent 58%),
      linear-gradient(180deg, color-mix(in srgb, var(--accent-light) 35%, var(--bg) 65%) 0%, color-mix(in srgb, var(--bg-secondary) 78%, var(--bg) 22%) 100%);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 16%, transparent);
  }

  .advice-header {
    margin-bottom: 1rem;
  }

  .eyebrow {
    margin: 0;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    color: var(--accent-text);
  }

  .advice-header h2 {
    margin: 0.2rem 0 0;
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--text);
  }

  .subtitle {
    margin: 0.35rem 0 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .advice-table {
    margin: 0;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, var(--border) 75%);
    border-radius: 10px;
    overflow: hidden;
    background: color-mix(in srgb, var(--bg) 88%, var(--accent-light) 12%);
  }

  .advice-row {
    display: grid;
    grid-template-columns: minmax(130px, 210px) 1fr;
    align-items: stretch;
    border-top: 1px solid color-mix(in srgb, var(--accent) 18%, var(--border) 82%);
  }

  .advice-row:first-child {
    border-top: 0;
  }

  .advice-row:nth-child(odd) {
    background: color-mix(in srgb, var(--accent-light) 24%, var(--bg) 76%);
  }

  .advice-row:nth-child(even) {
    background: color-mix(in srgb, var(--accent-light) 12%, var(--bg) 88%);
  }

  .advice-key {
    margin: 0;
    padding: 0.85rem 0.95rem;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: color-mix(in srgb, var(--accent-text) 85%, var(--text) 15%);
    font-weight: 700;
    border-right: 1px solid color-mix(in srgb, var(--accent) 20%, var(--border) 80%);
    background: color-mix(in srgb, var(--accent-light) 40%, var(--bg) 60%);
  }

  .advice-value {
    margin: 0;
    padding: 0.85rem 0.95rem;
    font-size: 0.95rem;
    line-height: 1.45;
    color: var(--text);
    font-weight: 500;
  }

  .advice-notes {
    margin: 0.95rem 0 0;
    padding: 0.9rem 0.95rem;
    border: 1px dashed color-mix(in srgb, var(--accent) 30%, var(--border) 70%);
    border-radius: 10px;
    background: color-mix(in srgb, var(--accent-light) 28%, var(--bg) 72%);
    color: var(--text);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .print-advice {
      padding: 1rem;
    }

    .advice-row {
      grid-template-columns: 1fr;
    }

    .advice-key {
      border-right: 0;
      border-bottom: 1px solid color-mix(in srgb, var(--accent) 20%, var(--border) 80%);
    }
  }
</style>
