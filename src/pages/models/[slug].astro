---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PrintAdvice from "../../components/PrintAdvice.astro";
import PaintingAdviceList from "../../components/PaintingAdviceList.astro";
import ModelGallery from "../../components/ModelGallery.astro";

export async function getStaticPaths() {
  const models = await getCollection("models");
  return models.map((model) => ({
    params: { slug: model.id },
    props: { model },
  }));
}

const { model } = Astro.props;
const { Content } = await render(model);
---

<BaseLayout title={model.data.title}>
  <article class="model-detail">
    <a href="/" class="back-link">← Back to Catalog</a>

    <h1>{model.data.title}</h1>

    <div class="model-meta">
      {model.data.material && (
        <div class="meta-item">
          <span class="meta-label">Material</span>
          <span class="meta-value">{model.data.material}</span>
        </div>
      )}
      {model.data.printTime && (
        <div class="meta-item">
          <span class="meta-label">Print Time</span>
          <span class="meta-value">{model.data.printTime}</span>
        </div>
      )}
      {model.data.date && (
        <div class="meta-item">
          <span class="meta-label">Added</span>
          <span class="meta-value">
            {model.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </span>
        </div>
      )}
      {(model.data.printAdvice ||
        (model.data.paintingAdvice && model.data.paintingAdvice.length > 0)) && (
        <div class="meta-actions" aria-label="Advice shortcuts">
          {model.data.printAdvice && (
            <a class="advice-link-button" href="#print-advice">
              Print Advice
            </a>
          )}
          {model.data.paintingAdvice && model.data.paintingAdvice.length > 0 && (
            <a class="advice-link-button" href="#painting-advice">
              Paint Advice
            </a>
          )}
        </div>
      )}
    </div>

    {model.data.tags && model.data.tags.length > 0 && (
      <div class="model-tags">
        {model.data.tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}

    <ModelGallery gallery={model.data.gallery} />

    <div class="model-content">
      <Content />
    </div>

    {model.data.downloadUrl && (
      <a
        class="download-button"
        href={model.data.downloadUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        Download this Model
      </a>
    )}

    <PrintAdvice printAdvice={model.data.printAdvice} />

    <PaintingAdviceList adviceSlugs={model.data.paintingAdvice} />

    <section class="usage-note" aria-label="Usage and license information">
      <p>
        Copyright Heidi Makes. Files are for personal use only, not for commercial use, and may
        not be redistributed. Commercial licenses are available for members of the <a href="https://www.printables.com/@erikaheidi#join.@erikaheidi.1686" title="Join Heidi Makes Club on Printables!">Heidi Makes Club</a> on
        the Printables platform.
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  .model-detail {
    max-width: 800px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--accent);
    font-weight: 500;
    font-size: 0.95rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .model-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 1rem;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .meta-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-text);
  }

  .meta-value {
    font-size: 0.95rem;
    color: var(--text);
  }

  .meta-actions {
    margin-left: auto;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .advice-link-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 40%, var(--border) 60%);
    background: color-mix(in srgb, var(--accent-light) 45%, var(--bg) 55%);
    color: var(--accent-text);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: transform 0.15s ease, filter 0.15s ease, border-color 0.15s ease;
  }

  .advice-link-button:hover {
    text-decoration: none;
    transform: translateY(-1px);
    filter: saturate(1.08);
    border-color: color-mix(in srgb, var(--accent) 58%, var(--border) 42%);
  }

  .advice-link-button:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 60%, transparent);
    outline-offset: 2px;
  }

  .model-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--tag-text);
  }

  .model-content {
    line-height: 1.75;
    font-size: 1.05rem;
    color: var(--text);
  }

  .model-content :global(h2) {
    font-size: 1.4rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--text);
  }

  .model-content :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
    color: var(--text);
  }

  .model-content :global(p) {
    margin-bottom: 1rem;
  }

  .model-content :global(ul),
  .model-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .model-content :global(li) {
    margin-bottom: 0.35rem;
  }

  .model-content :global(a) {
    color: var(--accent);
  }

  .model-content :global(code) {
    background: var(--bg-secondary);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .download-button {
    display: block;
    width: 100%;
    margin-top: 1.5rem;
    padding: 0.95rem 1.1rem;
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--accent) 75%, black 25%);
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--accent) 90%, white 10%) 0%,
      color-mix(in srgb, var(--accent) 68%, black 32%) 100%
    );
    color: var(--bg);
    font-size: 1rem;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    letter-spacing: 0.01em;
    text-shadow: 0 1px 0 color-mix(in srgb, black 35%, transparent);
    box-shadow:
      0 10px 24px color-mix(in srgb, var(--accent) 32%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 35%, transparent);
    transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease,
      border-color 0.18s ease;
  }

  .download-button:hover {
    text-decoration: none;
    transform: translateY(-2px);
    filter: saturate(1.18) brightness(1.04);
    border-color: color-mix(in srgb, var(--accent) 60%, white 40%);
    box-shadow:
      0 14px 28px color-mix(in srgb, var(--accent) 42%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 45%, transparent);
  }

  .download-button:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--accent) 40%, white 60%);
    outline-offset: 2px;
  }

  .usage-note {
    margin-top: 1.5rem;
    padding: 0.85rem 0.95rem;
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--border) 78%);
    border-radius: 10px;
    background: color-mix(in srgb, var(--bg-secondary) 86%, var(--accent-light) 14%);
  }

  .usage-note p {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .model-meta {
      gap: 1rem;
    }

    .meta-actions {
      width: 100%;
      margin-left: 0;
    }

    h1 {
      font-size: 1.5rem;
    }
  }
</style>
